# ==============================================================================
# AI Silent Disease Predictor — .gitignore
# ==============================================================================

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
*.egg
api/*.pyc

# Virtual environments
venv/
.venv/
env/

# Node.js / Frontend
node_modules/
.local/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
Thumbs.db
.DS_Store
desktop.ini

# Logs
logs/*.log

# Trained model artefacts (regenerated by train_model.py)
models/*.pkl

# Data (user should download/generate)
data/datasets/*.csv

# Streamlit
.streamlit/

# Misc
*.bak
*.tmp
server/public
vite.config.ts.*
*.tar.gz
